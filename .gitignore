# ---------------------------------------------------------------------------
# Node.js
# ---------------------------------------------------------------------------
node_modules/
dist/
build/
.next/
.nuxt/
.cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.env
.env.local
.env.*.local

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
*.egg-info/
dist/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.cover

# ---------------------------------------------------------------------------
# Ansible
# ---------------------------------------------------------------------------
# Archivos de Ansible Vault — NUNCA commitear secretos sin cifrar
*.vault
*.vault.yaml
*.vault.yml
vault-password
vault-password-file
.vault_pass
*vault_pass*
# Archivos generados por ansible
*.retry
ansible/roles/*/files/*.pem
ansible/roles/*/files/*.key

# ---------------------------------------------------------------------------
# Kind / Kubernetes
# ---------------------------------------------------------------------------
# Kubeconfigs generados por Kind — contienen credenciales del cluster
kubeconfig
*.kubeconfig
kubeconfig-*
.kube/

# Archivos de estado temporales de Kind
.kind/

# ---------------------------------------------------------------------------
# Secrets y certificados — regla general
# ---------------------------------------------------------------------------
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
secret.yaml
secrets.yaml
*-secret.yaml
*-secrets.yaml

# Exceptions: allow skeleton files in Backstage templates (these are templates, not real secrets)
!gitops/platform/backstage/templates/**/secret.yaml
!gitops/platform/backstage/templates/**/*-secret.yaml

# Exceptions: allow project base secret.yaml files (placeholder secrets managed by ArgoCD)
!gitops/platform/*/base/secret.yaml

# ---------------------------------------------------------------------------
# IDEs y sistema operativo
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
